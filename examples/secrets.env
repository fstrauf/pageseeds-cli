# PageSeeds Secrets Configuration
# Copy this file to: ~/.config/automation/secrets.env

# Required: CapSolver API key for Ahrefs SEO data
# Get one at: https://dashboard.capsolver.com/passport/register?inviteCode=1dTH7WQSfHD0
CAPSOLVER_API_KEY=your-capsolver-api-key-here

# Optional: Google Search Console Service Account
# For GSC indexing reports and page context
GSC_SERVICE_ACCOUNT_PATH=/path/to/service-account-key.json

# Optional: OAuth client secrets (alternative to service account)
GSC_REPORT_OAUTH_CLIENT_SECRETS=/path/to/oauth-client-secrets.json

# Optional: Reddit API credentials (for reddit posting features)
# Get your own at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# Optional: For automated posting (requires OAuth setup)
REDDIT_REFRESH_TOKEN=your-refresh-token
